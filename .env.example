# .env.example — copy to .env for local development, never commit .env
#
# The agent fetches all secrets (Gmail credentials, API keys) from Azure Key Vault
# at runtime using DefaultAzureCredential. Only non-secret config lives here.
#
# To authenticate locally:
#   az login
#   az account set --subscription <YOUR_SUBSCRIPTION_ID>

# ── Agent runtime config ───────────────────────────────────────────────────────

# Name of the Azure Key Vault instance (not the full URI — no ".vault.azure.net")
KEY_VAULT_NAME=your-keyvault-name

# Azure AI Foundry endpoint for the Claude Sonnet deployment
# Example: https://<your-project>.openai.azure.com/
AZURE_FOUNDRY_ENDPOINT=https://your-foundry-project.openai.azure.com/

# Name of the model deployment in Azure AI Foundry
AZURE_FOUNDRY_DEPLOYMENT=claude-sonnet

# How often the agent polls the Gmail inbox (seconds). Default: 60
POLL_INTERVAL_SECONDS=60

# ── Azure identity (used by DefaultAzureCredential on the VM) ─────────────────
# On the VM these are provided automatically by the managed identity.
# For local dev with a service principal instead of `az login`:

# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-service-principal-client-id
# AZURE_CLIENT_SECRET=your-service-principal-client-secret

# ── Terraform / pipeline variables (set in Azure DevOps variable groups) ───────
# These are NOT read by the Python agent — they are used by the CI/CD pipeline.

# ARM_SERVICE_CONNECTION=your-ado-service-connection-name
# TF_BACKEND_RESOURCE_GROUP=rg-tfstate
# TF_BACKEND_STORAGE_ACCOUNT=yourstorageaccount
# TF_BACKEND_CONTAINER=tfstate
# TF_VAR_admin_ssh_public_key=ssh-rsa AAAA...
# ADMIN_SSH_PUBLIC_KEY=ssh-rsa AAAA...   (pipeline variable — same value)
# AGENT_VM_USER=azureuser
# AGENT_VM_IP=10.0.1.4                  (from terraform output vm_private_ip)
# AGENT_SSH_PRIVATE_KEY=<contents of private key>
# APPROVER_EMAIL=you@example.com
